# Web3Forms API key — get yours free at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Leave empty to disable GA4 tracking
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token
# Get from: Search Console > Settings > Ownership Verification > HTML tag method
# Only the content="" value, not the full meta tag
NEXT_PUBLIC_GSC_VERIFICATION=
